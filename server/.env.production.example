NODE_ENV=production
DATABASE_PROVIDER=postgresql
DATABASE_URL=postgresql://USER:PASSWORD@db-host:5432/bluemeteor_ai_force?schema=public
STORAGE_ROOT=/var/lib/bluemeteor/storage

CORS_ORIGIN=https://your-frontend-host.example.com
API_GLOBAL_PREFIX=

JWT_ACCESS_SECRET=min-32-chars-distinct-secret-xxxxxxxx
JWT_REFRESH_SECRET=min-32-chars-distinct-secret-yyyyyyyy
STREAM_TOKEN_SECRET=min-32-chars-dedicated-stream-secret

AUTH_DEMO_USERS_ENABLED=false
SEED_DEFAULT_ADMIN=false
DEFAULT_ADMIN_PASSWORD=strong-unique-password-required-if-seeding-admin

AGENT_PROVIDER=openai
OPENAI_API_KEY=set-me
AGENT_ALLOW_PROVIDER_FALLBACK=false
ALLOW_PROVIDER_FALLBACK=false

ENABLE_CONNECTOR_MOCK_FALLBACK=false
ALLOW_MOCK_FALLBACK_IN_PRODUCTION=false
ENABLE_DIRECT_BROWSER_DEBUG_ENDPOINTS=false
MCP_USE_MOCK_CLIENT_ON_FAILURE=false

ENABLE_METRICS=true
METRICS_PUBLIC=false
STRUCTURED_LOGGING=true
