# Prefer the root `.env` when using docker compose (see ../.env.docker.example).
# This file documents backend-only variables for custom deployments.

NODE_ENV=production
DATABASE_PROVIDER=postgresql
DATABASE_URL=postgresql://USER:PASSWORD@postgres:5432/bluemeteor_ai_force?schema=public
STORAGE_ROOT=/data/storage
CORS_ORIGIN=http://localhost:8080
AGENT_ALLOW_PROVIDER_FALLBACK=false
ALLOW_PROVIDER_FALLBACK=false
