{
	"name": "bluemeteor-ai-force-agent-server",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"build": "prisma generate && nest build",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:prod": "node dist/main",
		"prisma:generate": "prisma generate",
		"prisma:generate:postgres": "node scripts/sync-postgres-schema.mjs && prisma generate --schema=prisma/postgres/schema.prisma",
		"prisma:migrate": "prisma migrate dev",
		"prisma:migrate:deploy": "prisma migrate deploy --schema=prisma/postgres/schema.prisma",
		"prisma:studio": "prisma studio",
		"prisma:reset": "prisma migrate reset",
		"db:seed": "node dist/scripts/seed.js",
		"db:health": "node scripts/db-health.mjs",
		"playwright:install": "playwright install chromium"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.39.0",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@nestjs/common": "^11.0.0",
		"@nestjs/config": "^4.0.0",
		"@nestjs/core": "^11.0.0",
		"@nestjs/jwt": "^11.0.0",
		"@nestjs/passport": "^11.0.0",
		"@nestjs/platform-express": "^11.0.0",
		"@nestjs/throttler": "^6.4.0",
		"@prisma/client": "^6.0.0",
		"bcryptjs": "^3.0.2",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.1",
		"openai": "^4.77.0",
		"passport": "^0.7.0",
		"passport-jwt": "^4.0.1",
		"playwright": "^1.49.0",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@nestjs/cli": "^11.0.0",
		"@nestjs/schematics": "^11.0.0",
		"@types/bcryptjs": "^2.4.6",
		"@types/express": "^4.17.21",
		"@types/node": "^22.10.0",
		"@types/passport-jwt": "^4.0.1",
		"prisma": "^6.0.0",
		"typescript": "^5.7.2"
	}
}
