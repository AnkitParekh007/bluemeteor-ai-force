PORT=3000
NODE_ENV=development

DATABASE_URL="file:./dev.db"

AGENT_PROVIDER=mock
AGENT_STREAMING_ENABLED=true
# Back-compat: same as AGENT_ALLOW_PROVIDER_FALLBACK
AGENT_ALLOW_PROVIDER_FALLBACK=true
ALLOW_PROVIDER_FALLBACK=true

AGENT_MAX_MESSAGE_CHARS=12000
ENABLE_DEBUG_RUNTIME_LOGS=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

LOCAL_MODEL_BASE_URL=http://localhost:11434
LOCAL_MODEL_NAME=llama3.1

CORS_ORIGIN=http://localhost:4200

ENABLE_APPROVAL_GATES=true
ENABLE_AUDIT_LOGS=true

# --- Browser worker (Playwright) — disabled by default ---
ENABLE_BROWSER_WORKER=false
ENABLE_REAL_BROWSER_ACTIONS=false
BROWSER_HEADLESS=true
BROWSER_DEFAULT_URL=http://localhost:4200
BROWSER_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4300
BROWSER_SESSION_TIMEOUT_MS=900000
BROWSER_ACTION_TIMEOUT_MS=15000
BROWSER_MAX_ACTIONS_PER_RUN=25
BROWSER_SCREENSHOT_ENABLED=true
BROWSER_SCREENSHOT_DIR=storage/browser-screenshots

# Browser authentication/session profiles
ENABLE_AUTHENTICATED_BROWSER_SESSIONS=false
BROWSER_AUTH_STATE_DIR=storage/browser-auth-states
BROWSER_SESSION_PROFILE_DIR=storage/browser-profiles
BROWSER_RECORD_VIDEO=false
BROWSER_VIDEO_DIR=storage/browser-videos
BROWSER_TRACE_ENABLED=false
BROWSER_TRACE_DIR=storage/browser-traces

# Test target app
TEST_TARGET_BASE_URL=http://localhost:4200
TEST_TARGET_LOGIN_URL=http://localhost:4200/login
TEST_TARGET_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4300
TEST_TARGET_ENVIRONMENT=local

# Demo login only for local/dev (never use real production passwords here)
ENABLE_DEMO_BROWSER_LOGIN=true
DEMO_BROWSER_USERNAME=bluemeteor
DEMO_BROWSER_PASSWORD=bluemeteor

# Playwright test execution
ENABLE_REAL_PLAYWRIGHT_TESTS=false
PLAYWRIGHT_TEST_OUTPUT_DIR=storage/playwright-results
PLAYWRIGHT_GENERATED_SPEC_DIR=storage/generated-tests
PLAYWRIGHT_MAX_TEST_DURATION_MS=120000
PLAYWRIGHT_MAX_TESTS_PER_RUN=10
PLAYWRIGHT_ALLOWED_TEST_TEMPLATES=login_smoke,dashboard_smoke,supplier_upload_smoke
PLAYWRIGHT_CAPTURE_SCREENSHOT_ON_FAILURE=true
PLAYWRIGHT_CAPTURE_TRACE_ON_FAILURE=false

# Safety
ALLOW_TESTS_AGAINST_PRODUCTION=false
REQUIRE_APPROVAL_FOR_AUTH_BROWSER=true
REQUIRE_APPROVAL_FOR_REAL_TEST_RUN=true

# --- Test worker ---
ENABLE_TEST_WORKER=true
TEST_RUN_TIMEOUT_MS=120000

# --- Tool / approval policy ---
ENABLE_TOOL_APPROVALS=true
AUTO_APPROVE_LOW_RISK_TOOLS=true
BLOCK_HIGH_RISK_TOOLS_WITHOUT_APPROVAL=true

# ——— Auth / RBAC / rate limits ———
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

AUTH_DEMO_USERS_ENABLED=true
AUTH_REQUIRE_STRONG_PASSWORD=false

BCRYPT_SALT_ROUNDS=10

ENABLE_RBAC=true
ENABLE_RATE_LIMITING=true

RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
AGENT_RATE_LIMIT_MAX_REQUESTS=30
BROWSER_RATE_LIMIT_MAX_REQUESTS=20

DEFAULT_ADMIN_EMAIL=admin@bluemeteor.local
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_NAME=Admin User

# ——— Internal read-only tool hub ———
ENABLE_INTERNAL_TOOLS=true
ENABLE_REPOSITORY_READER=true
ENABLE_DOCS_READER=true
ENABLE_TICKET_READER=true
ENABLE_API_CATALOG_READER=true
ENABLE_DATABASE_SCHEMA_READER=true
ENABLE_CICD_READER=true
ENABLE_MCP_ADAPTER=false
MCP_CONFIG_PATH=server/mcp.config.json
MCP_SERVER_STARTUP_TIMEOUT_MS=15000
MCP_TOOL_CALL_TIMEOUT_MS=30000
MCP_MAX_OUTPUT_CHARS=50000
MCP_ALLOW_STDIO=true
MCP_ALLOW_HTTP=true
MCP_ALLOW_SSE=false
MCP_ALLOW_WRITE_TOOLS=false
MCP_ALLOWED_COMMANDS=npx,node,bun,python
MCP_WORKING_DIRECTORY=.
MCP_DEBUG_LOGS=false
MCP_USE_MOCK_CLIENT_ON_FAILURE=true

REPOSITORY_PROVIDER=local
REPOSITORY_ROOT=../
REPOSITORY_ALLOWED_PATHS=src,server,docs,README.md,package.json,angular.json

DOCS_ROOT=docs
TICKETS_PROVIDER=mock
API_CATALOG_PATH=docs/api-catalog.json
DATABASE_SCHEMA_PATH=docs/database-schema.md
CICD_ALLOWED_FILES=.github,bitbucket-pipelines.yml,server/package.json,package.json,angular.json

MAX_TOOL_FILE_READ_BYTES=200000

# ——— Connector hub (read-only; secrets stay on server) ———
ENABLE_CONNECTORS=true
ENABLE_CONNECTOR_MOCK_FALLBACK=true

CONNECTOR_HTTP_TIMEOUT_MS=15000
CONNECTOR_MAX_RESULTS=20
CONNECTOR_MAX_CONTENT_CHARS=60000

# Bitbucket
ENABLE_BITBUCKET_CONNECTOR=false
BITBUCKET_BASE_URL=https://api.bitbucket.org/2.0
BITBUCKET_WORKSPACE=
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=
BITBUCKET_DEFAULT_REPO=
BITBUCKET_ALLOWED_REPOS=

# GitHub
ENABLE_GITHUB_CONNECTOR=false
GITHUB_BASE_URL=https://api.github.com
GITHUB_TOKEN=
GITHUB_DEFAULT_OWNER=
GITHUB_ALLOWED_REPOS=

# Jira
ENABLE_JIRA_CONNECTOR=false
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEYS=

# Confluence
ENABLE_CONFLUENCE_CONNECTOR=false
CONFLUENCE_BASE_URL=
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_KEYS=

# Support tickets
ENABLE_SUPPORT_CONNECTOR=false
SUPPORT_CONNECTOR_PROVIDER=mock
ZENDESK_BASE_URL=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=
SERVICENOW_BASE_URL=
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=

# CI/CD (connector layer; uses local repo reader when CICD_PROVIDER=local)
ENABLE_CICD_CONNECTOR=true
CICD_PROVIDER=local
CICD_ALLOWED_FILES=.github,bitbucket-pipelines.yml,azure-pipelines.yml,Jenkinsfile,Dockerfile,docker-compose.yml,package.json,server/package.json
