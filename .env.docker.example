# Copy to project root as `.env` for docker compose (never commit `.env`).
# Use a strong POSTGRES_PASSWORD (not change-me / bluemeteor / postgres / password).

POSTGRES_USER=bluemeteor
POSTGRES_PASSWORD=PilotComposeDb-Secret-Replace-Me-32chars
POSTGRES_DB=bluemeteor_ai_force

FRONTEND_PORT=8080
CORS_ORIGIN=http://localhost:8080

DATABASE_URL=postgresql://bluemeteor:PilotComposeDb-Secret-Replace-Me-32chars@postgres:5432/bluemeteor_ai_force?schema=public

JWT_ACCESS_SECRET=replace-with-32-plus-char-secret-one-xxxxxxxx
JWT_REFRESH_SECRET=replace-with-32-plus-char-secret-two-xxxxxxxx
STREAM_TOKEN_SECRET=replace-with-32-plus-char-stream-secret-xxxx

DEFAULT_ADMIN_PASSWORD=Replace-With-Strong-Admin-Password-12+
SEED_DEFAULT_ADMIN=true
AUTH_DEMO_USERS_ENABLED=false

AGENT_PROVIDER=mock
ENABLE_CONNECTOR_MOCK_FALLBACK=true
ALLOW_MOCK_FALLBACK_IN_PRODUCTION=true

ENABLE_METRICS=true
METRICS_PUBLIC=false
STRUCTURED_LOGGING=true
